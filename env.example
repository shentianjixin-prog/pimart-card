# 复制为 .env 后填写（不要提交 .env）

# SQLite 数据库
# 本地：file:./dev.db
# Railway：启动脚本自动设为 file:/data/dev.db（需挂载 Volume /data）
DATABASE_URL="file:./dev.db"

# Stripe（测试密钥以 sk_test_ / pk_test_ 开头）
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# 设为 true 后 Footer 隐藏「测试模式」提示（需配合 live 密钥）
NEXT_PUBLIC_STRIPE_LIVE=false

# 管理后台 Session 密钥（生产环境务必改为随机长字符串）
ADMIN_SESSION_SECRET=change-me-in-production

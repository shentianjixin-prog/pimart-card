// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// 商品（原盒 / 周边 / 卡牌）
model Product {
  id             String      @id @default(cuid())
  name           String
  slug           String      @unique
  category       String
  series         String?
  cardNumber     String? // 卡号，如 SV10-109
  rarity         String? // 稀有度，如 SR / SAR
  language       String? // 语言版本，如 简中 / 日版
  description    String?
  priceJpy       Int
  stock          Int         @default(0)
  images         String
  boxType        String      @default("")
  featured       Boolean     @default(false)
  isPreorder     Boolean     @default(false)
  shippingDays   Int         @default(6)
  releaseDate    DateTime?
  costPrice      Int?
  marketRefPrice Int?
  minPrice       Int?
  status         String      @default("上架") // 上架 / 下架
  researchStatus String?
  priceUpdatedAt DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  orderItems     OrderItem[]
}

// 订单
model Order {
  id              String      @id @default(cuid())
  stripeSessionId String?     @unique
  customerEmail   String?
  customerName    String?
  status          String      @default("pending") // pending/paid/cancelled
  totalJpy        Int
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
}

// 订单明细
model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int
  priceJpy  Int // 下单时单价快照
}

// 后台管理员
model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

// 买取咨询
model BuybackRequest {
  id        String   @id @default(cuid())
  name      String
  nameKana  String
  email     String
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
}
